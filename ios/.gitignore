# XcodeGen generates the project from project.yml — don't commit the generated project.
*.xcodeproj/
*.xcworkspace/
# XcodeGen-generated Info.plist (generated from project.yml `info:` block).
ATCTranscribe/Info.plist

# Xcode build output / user state
DerivedData/
build/
.build/
*.xcuserstate
xcuserdata/
*.xcscmblueprint

# Swift Package Manager
.swiftpm/

# Converted CoreML model bundles (large; produced by Tools/ conversion, distributed separately)
*.mlmodelc
*.mlpackage
# Ignore the bundled model's heavy contents but keep the dir tracked (.gitkeep) so the
# project.yml folder reference always resolves. Keep the empty `llm/` subdir tracked too —
# Tools/fetch_llm_model.sh drops the GGUF there (also heavy, so still ignored).
ATCTranscribe/Resources/Models/*
!ATCTranscribe/Resources/Models/.gitkeep
!ATCTranscribe/Resources/Models/llm/
ATCTranscribe/Resources/Models/llm/*
!ATCTranscribe/Resources/Models/llm/.gitkeep

# The Replay-demo clips are deliberately bundled into the app, so re-include them despite
# the repo-root `*.wav` rule (which exists to keep training/audio corpora out of git).
!ATCTranscribe/Resources/DemoClips/*.wav

# macOS
.DS_Store
