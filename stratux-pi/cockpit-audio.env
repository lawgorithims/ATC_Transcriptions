# CommSight cockpit-audio gateway configuration (installed to /etc/default/cockpit-audio).
# After editing, apply with:  sudo systemctl restart cockpit-audio

# ALSA capture device. "auto" detects a USB audio adapter; or set an explicit device.
# See your devices with:  arecord -l   (or:  /opt/commsight/detect-audio)
AUDIO_DEVICE=auto

# HTTP port CommSight reads /audio.raw from. Must match the app's
# Settings -> Stratux receiver -> Audio port.
AUDIO_PORT=8090

# Capture format. CommSight expects 16 kHz mono 16-bit PCM — leave these unless you know why.
AUDIO_RATE=16000
AUDIO_CHANNELS=1
AUDIO_FORMAT=S16_LE

# LED input meter: the Pi's GREEN (ACT) LED flickers while audio is present at the capture
# input, the RED (PWR) LED lights when the signal clips. Works with no iPad connected — the
# meter releases the mic the instant a client streams. Set LED_METER=off to leave the LEDs
# to their normal duties (SD activity / power).
LED_METER=on
# Green flickers while the chunk RMS is above this (dBFS). Raise it (e.g. -40) if electrical
# noise keeps the LED flickering with nothing playing.
LED_THRESHOLD_DBFS=-50
# Red lights when a peak crosses this (dBFS): your cue to turn the inline volume down.
LED_CLIP_DBFS=-3
