# CommSight cockpit-audio gateway configuration (installed to /etc/default/cockpit-audio).
# After editing, apply with:  sudo systemctl restart cockpit-audio

# ALSA capture device. "auto" detects a USB audio adapter; or set an explicit device.
# See your devices with:  arecord -l   (or:  /opt/commsight/detect-audio)
AUDIO_DEVICE=auto

# HTTP port CommSight reads /audio.raw from. Must match the app's
# Settings -> Stratux receiver -> Audio port.
AUDIO_PORT=8090

# Capture format. CommSight expects 16 kHz mono 16-bit PCM — leave these unless you know why.
AUDIO_RATE=16000
AUDIO_CHANNELS=1
AUDIO_FORMAT=S16_LE
